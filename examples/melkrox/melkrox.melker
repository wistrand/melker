<melker>
<!-- Melkrox: AI Text Adventure Engine -->
<policy>
  {
    "name": "melkrox",
    "description": "AI-powered text adventure game via OpenRouter",
    "permissions": {
      "net": ["openrouter.ai"],
      "env": ["OPENROUTER_API_KEY"],
      "shader": true,
      "browser": true,
      "clipboard": true
    },
    "configSchema": {
      "openrouter.key": {
        "type": "string",
        "env": "OPENROUTER_API_KEY"
      },
      "openrouter.model": {
        "type": "string",
        "default": "google/gemini-2.5-flash"
      },
      "openrouter.imageModel": {
        "type": "string",
        "default": "google/gemini-3.1-flash-image-preview"
      },
      "openrouter.visionModel": {
        "type": "string",
        "default": "google/gemini-2.5-flash"
      },
      "openrouter.skipImages": {
        "type": "boolean",
        "default": "false",
        "env": "MELKROX_SKIP_IMAGES"
      }
    }
  }
</policy>

<style>
  #root {
    padding: 1;
    gap: 0;
    height: 100%;
  }
  #title-bar {
    font-weight: bold;
    text-align: center;
    flex-shrink: 0;
  }
  #status-bar {
    padding-top: 1;
    padding-left: 2;
    padding-right: 2;
    flex-shrink: 0;
  }
  #choices-bar {
    flex-direction: row;
    gap: 1;
    flex-wrap: wrap;
    padding-top: 1;
  }
  .choice-btn {
    color: var(--theme-button-secondary);
    padding-left: 1;
    padding-right: 1;
  }
  #input-row {
    flex-direction: row;
    gap: 1;
    padding-top: 1;
    padding-left: 2;
    padding-right: 2;
  }
  #cmd-input {
    flex-grow: 1;
  }
  #narrative-wrap {
    flex-grow: 1;
    overflow-y: auto;
    min-height: 4;
    padding: 2;
  }
  #narrative {
    text-wrap: wrap;
  }
  #setup-prompt {
    flex-grow: 1;
    height: 5;
  }
  #setup-container {
    gap: 1;
    padding: 2;
  }
  #setup-row {
    flex-direction: row;
    gap: 1;
  }
  #genre-row {
    flex-direction: row;
    gap: 1;
    padding-top: 1;
    flex-wrap: wrap;
  }
  #log-area {
    padding-top: 1;
    padding-bottom: 1;
    padding-left: 2;
    padding-right: 2;
    height: 5;
    overflow-y: scroll;
    flex-shrink: 0;
    color: var(--theme-text-muted);
  }
  #games-list {
    gap: 1;
    overflow-y: auto;
    flex-grow: 1;
    flex-shrink: 1;
  }
  .game-entry {
    flex-direction: row;
    gap: 2;
    padding: 1;
    background: var(--theme-surface);
  }
  .game-entry-info {
    flex-grow: 1;
    flex-shrink: 1;
    overflow: hidden;
  }
  .game-entry-actions {
    flex-direction: row;
    gap: 1;
    flex-shrink: 0;
  }
</style>

<!-- Loading screen -->
<container id="loading-screen" style="padding: 2; gap: 1;">
  <text style="font-weight: bold; text-align: center;">MELKROX</text>
  <spinner id="loading-spinner" variant="braille" verbs="loading" shade="true" />
  <container id="loading-log" style="padding-top: 1; max-height: 6; overflow: scroll;"></container>
</container>

<!-- Game select screen -->
<container id="select-screen" style="display: none; padding: 2; gap: 1; height: fill;">
  <text style="font-weight: bold; text-align: center; flex-shrink: 0;">MELKROX - Saved Games</text>
  <button label="New Game" onClick="$app.newGame()" style="flex-shrink: 0;" />
  <container id="games-list"></container>
</container>

<!-- Setup screen -->
<container id="setup-container" style="display: none; height: fill;">
  <container style="padding: 4; gap: 2;">
    <text style="font-weight: bold; text-align: center; padding-bottom: 1;">MELKROX - New Adventure</text>
    <text style="text-align: center; color: var(--theme-text-muted);">Choose a genre or describe your own world</text>
    <container id="genre-row" style="padding-top: 1">
      <button id="g1" label="Dark Fantasy" onClick="$app.generateGenre('dark fantasy')" />
      <button id="g2" label="Sci-Fi" onClick="$app.generateGenre('lighthearted sci-fi exploration')" />
      <button id="g3" label="Horror" onClick="$app.generateGenre('horror')" />
      <button id="g4" label="Heist" onClick="$app.generateGenre('heist caper with humor')" />
      <button id="g5" label="Slice of Life" onClick="$app.generateGenre('cozy slice of life')" />
      <button id="g6" label="Road Trip" onClick="$app.generateGenre('feel-good road trip comedy')" />
      <button id="g7" label="Comedy" onClick="$app.generateGenre('absurdist comedy')" />
      <button id="g8" label="Mystery" onClick="$app.generateGenre('mystery')" />
      <button id="g9" label="Romance" onClick="$app.generateGenre('romantic comedy')" />
      <button id="g10" label="Pirate" onClick="$app.generateGenre('swashbuckling pirate adventure')" />
      <button id="g11" label="Toy Adventure" onClick="$app.generateGenre('toys animals on candy search')" />
    </container>
    <container id="setup-row" style="padding-top: 1;">
      <textarea id="setup-prompt" placeholder="Or type your own story prompt..." rows="5" onChange="$app.onPromptChange()" />
    </container>
    <container id="restyle-row" style="flex-direction: row; gap: 1; justify-content: center; display: none;">
      <button label="Darker" variant="plain" onClick="$app.restylePrompt('darker and more ominous')" />
      <button label="Lighter" variant="plain" onClick="$app.restylePrompt('lighter and more humorous')" />
      <button label="Grittier" variant="plain" onClick="$app.restylePrompt('grittier and more realistic')" />
      <button label="Weirder" variant="plain" onClick="$app.restylePrompt('stranger and more surreal')" />
      <button label="Cozier" variant="plain" onClick="$app.restylePrompt('cozier and more intimate')" />
      <button label="Enrich" variant="plain" onClick="$app.restylePrompt('more vivid and evocative — use richer words but keep the same length')" />
    </container>
    <button label="Start Adventure" onClick="$app.startGame()" />
    <container style="flex-direction: row; gap: 2; justify-content: center;">
      <button label="Clear" variant="plain" onClick="$app.clearPrompt()" />
      <button label="Load from file..." variant="plain" onClick="$app.openFilePicker()" />
      <button id="back-to-games" label="Saved Games" variant="plain" onClick="$app.showSavedGames()" style="display: none;" />
    </container>
    <text id="setup-error" style="display: none;"></text>
    <container id="setup-progress" style="height: 8; align-items: center; gap: 1; padding-top: 1;">
      <spinner id="setup-spinner" variant="braille" verbs="Creating world" spinning="false" shade="true" style="visibility: hidden;" />
      <container id="setup-log" style="display: none; max-height: 6; overflow: scroll; width: 100%; color: var(--theme-text-muted);"></container>
    </container>
  </container>
</container>

<!-- File picker dialog -->
<dialog id="file-dialog" title="Load Story File" open="false" modal="true" width="70" height="20">
  <file-browser
    id="file-picker"
    selectionMode="single"
    selectType="file"
    onSelect="$app.handleFileSelect(event)"
    onCancel="$app.closeFilePicker()"
    maxVisible="14"
  />
</dialog>

<dialog id="help-dialog" title="Commands" open="false" width="55" height="18" draggable="true" closable="true" backdrop="false">
  <container style="overflow: scroll; height: fill; padding: 1;">
    <markdown text="- Type anything to interact with the world
- `/new` — Start a new game
- `/games` — Switch between saved games
- `/state` — Show world facts (AI's long-term memory)
- `/story` — Full story recap with images
- `/history` — Show recent turns
- `/undo` — Go back one turn
- `/redo` — Go forward one turn
- `/image` — Open scene image in browser
- `/reimage [style]` — Regenerate scene image (optional custom style)
- `/images` — Toggle image generation on/off
- `/gfx [mode]` — Set gfx mode (sextant/halfblock/quadrant/pattern/luma/reset)
- `/dither [bits]` — Set dither bits (1/2/4/8/reset)
- `/mood [effect] [effect]` — Set mood shader(s), up to 2 layered (lightning/rain/bloom/sunrays/glitch/fog/fire/underwater/snow/darkness/sandstorm/magic/heat/off)
- `/cost [on|off]` — Toggle session token/cost display
- `/help` — Show this help" />
  </container>
</dialog>

<!-- Game screen -->
<container id="game-screen" style="display: none; height: fill; flex-grow: 1;">
  <text id="title-bar">MELKROX</text>
  <split-pane sizes="2,1" style="width: fill; flex-grow: 1; direction: vertical;">
    <img id="scene-image" width="100%" height="fill" style="object-fit: contain;" dither="sierra-stable" ditherBits="8" onClick="$app.handleImageClick(event)" onMouseOver="$app.handleImageMouseOver()" onMouseOut="$app.handleImageMouseOut()" />
    <container id="narrative-wrap">
      <markdown id="narrative" text="" />
    </container>
  </split-pane>
  <text id="status-bar"></text>
  <container style="padding-left: 2; padding-right: 2;">
    <container id="choices-bar"></container>
  </container>
  <container id="input-row">
    <input id="cmd-input" placeholder="> What do you do?" onKeyPress="$app.handleInput()" />
    <button label="Send" onClick="$app.handleInput()" />
  </container>
    <container style="padding-left: 2"><spinner id="game-spinner" variant="dots" verbs="thinking" spinning="false" shade="true" style="visibility: hidden; padding-left: 2;" /></container>
  <container id="log-area"></container>
  <text id="cost-bar" style="display: none; padding-left: 2; color: var(--theme-text-muted);"></text>
</container>

<script>

const CACHE_NS = 'melkrox';
const MAX_HISTORY = 20;
const MAX_CACHED_IMAGES = 20;
const encoder = new TextEncoder();
const decoder = new TextDecoder();

let apiKey = '';
let model = '';
let setupModel = '';
let imageModel = '';
let visionModel = '';
let gameState = null;
let currentGameId = null;
let currentImage = null; // Scene image data URL (not saved in game state)
let lastRenderedImage = null; // Track which image was last rendered to detect new arrivals
let gamesIndex = []; // [{id, title, turnCount, location, lastPlayed}]
let imageAbort = null; // AbortController for in-flight image request
let skipImages = false;
let turnBusy = false;
let redoStack = []; // [{user, assistant}] for redo after undo
let sessionTokens = { prompt: 0, completion: 0 };
let sessionCost = 0; // accumulated cost in credits (if reported by API)

function trackUsage(usage) {
  if (!usage) return;
  sessionTokens.prompt += usage.prompt_tokens || 0;
  sessionTokens.completion += usage.completion_tokens || 0;
  if (usage.cost) sessionCost += usage.cost;
  updateCostBar();
}

function updateCostBar() {
  const bar = $melker.getElementById('cost-bar');
  if (bar.props.style?.display === 'none') return;
  const totalTokens = sessionTokens.prompt + sessionTokens.completion;
  if (totalTokens === 0) { bar.props.text = ''; return; }
  const parts = [
    (sessionTokens.prompt / 1000).toFixed(1) + 'k in',
    (sessionTokens.completion / 1000).toFixed(1) + 'k out'
  ];
  if (sessionCost > 0) parts.push('$' + sessionCost.toFixed(4));
  bar.props.text = parts.join(' | ');
}

function usageSuffix() {
  const totalTokens = sessionTokens.prompt + sessionTokens.completion;
  if (totalTokens === 0) return '';
  const parts = [(totalTokens / 1000).toFixed(1) + 'k tok'];
  if (sessionCost > 0) parts.push('$' + sessionCost.toFixed(4));
  return ' | ' + parts.join(', ');
}

// --- Game Index ---

async function loadGamesIndex() {
  const data = await $melker.cache.read(CACHE_NS, 'games');
  if (data) {
    try {
      gamesIndex = JSON.parse(decoder.decode(data));
    } catch (_) {
      gamesIndex = [];
    }
  } else {
    // Migrate from old single-game format
    const oldState = await $melker.cache.read(CACHE_NS, 'state');
    if (oldState) {
      try {
        const state = JSON.parse(decoder.decode(oldState));
        const id = 'game_' + Date.now();
        gamesIndex = [{
          id: id,
          title: state.worldConfig?.title || 'Untitled',
          turnCount: state.turnCount || 0,
          location: state.location || 'Unknown',
          lastPlayed: new Date().toISOString()
        }];
        await $melker.cache.write(CACHE_NS, 'game:' + id, oldState);
        await saveGamesIndex();
        await $melker.cache.delete(CACHE_NS, 'state');
        logger.info('Migrated old save to multi-game format, id=' + id);
      } catch (_) {
        gamesIndex = [];
      }
    }
  }
  return gamesIndex;
}

async function saveGamesIndex() {
  await $melker.cache.write(CACHE_NS, 'games', encoder.encode(JSON.stringify(gamesIndex)));
}

function generateGameId() {
  return 'game_' + Date.now() + '_' + Math.random().toString(36).slice(2, 6);
}

function renderGamesList() {
  const list = $melker.getElementById('games-list');
  list.children = [];

  if (gamesIndex.length === 0) {
    list.children.push($melker.createElement('text', { text: 'No saved games. Start a new adventure!' }));
    return;
  }

  // Sort by last played (most recent first)
  const sorted = [...gamesIndex].sort((a, b) => (b.lastPlayed || '').localeCompare(a.lastPlayed || ''));

  for (const game of sorted) {
    const row = $melker.createElement('container', { class: 'game-entry' });

    const info = $melker.createElement('container', { class: 'game-entry-info' });
    info.children.push($melker.createElement('text', {
      text: game.title || 'Untitled',
      style: { fontWeight: 'bold' }
    }));
    info.children.push($melker.createElement('text', {
      text: 'Turn ' + (game.turnCount || 0) + ' | ' + (game.location || 'Unknown'),
      style: { color: 'var(--theme-text-muted)' }
    }));

    const actions = $melker.createElement('container', { class: 'game-entry-actions' });
    const gameId = game.id;
    actions.children.push($melker.createElement('button', {
      label: 'Play',
      onClick: () => $app.loadGame(gameId)
    }));
    actions.children.push($melker.createElement('button', {
      label: 'Clone',
      variant: 'plain',
      onClick: () => $app.cloneGame(gameId)
    }));
    actions.children.push($melker.createElement('button', {
      label: 'Delete',
      variant: 'plain',
      style: { color: 'var(--theme-text-muted)' },
      onClick: () => $app.deleteGame(gameId)
    }));

    row.children.push(info);
    row.children.push(actions);
    list.children.push(row);
  }
}

export async function loadGame(id) {
  const data = await $melker.cache.read(CACHE_NS, 'game:' + id);
  if (!data) {
    logger.warn('Game not found: ' + id);
    return;
  }
  try {
    gameState = JSON.parse(decoder.decode(data));
    currentGameId = id;
    setMoodShader(gameState.mood || null, true);
    // Load current image from cache
    currentImage = null;
    const imgKey = 'image:' + id + ':' + gameState.turnCount;
    const cachedImg = await $melker.cache.read(CACHE_NS, imgKey);
    if (cachedImg) currentImage = decoder.decode(cachedImg);
    // Migrate: remove currentImage from old game state if present
    if (gameState.currentImage) { delete gameState.currentImage; }
    // Migrate: rebuild facts from worldConfig + history if missing
    if (!gameState.facts) {
      gameState.facts = rebuildFacts(gameState);
      logger.info('Migrated game: rebuilt ' + Object.keys(gameState.facts).length + ' facts from worldConfig');
    }
    logger.info('Loaded game "' + (gameState.worldConfig?.title || id) + '" turn=' + gameState.turnCount);
    // Update lastPlayed so auto-resume picks the right game
    const entry = gamesIndex.find(g => g.id === id);
    if (entry) {
      entry.lastPlayed = new Date().toISOString();
      await saveGamesIndex();
    }
    showGameScreen();
    renderScene();
    focusInput();
    $melker.render();
  } catch (e) {
    logger.error('Failed to load game ' + id + ': ' + e.message);
  }
}

export async function deleteGame(id) {
  gamesIndex = gamesIndex.filter(g => g.id !== id);
  await saveGamesIndex();
  await $melker.cache.delete(CACHE_NS, 'game:' + id);
  // Delete associated images
  const allKeys = await $melker.cache.scan(CACHE_NS);
  const prefix = 'image:' + id + ':';
  for (const k of allKeys) {
    if (k.startsWith(prefix)) {
      await $melker.cache.delete(CACHE_NS, k);
    }
  }
  logger.info('Deleted game ' + id);
  renderGamesList();
  $melker.render();
}

export async function cloneGame(id) {
  const data = await $melker.cache.read(CACHE_NS, 'game:' + id);
  if (!data) {
    logger.warn('Game not found for cloning: ' + id);
    return;
  }
  try {
    const original = JSON.parse(decoder.decode(data));
    const prompt = original.storyPrompt;
    if (!prompt) {
      $melker.toast.show('Cannot clone: game has no saved story prompt', { type: 'warning' });
      return;
    }
    // Switch to setup screen with the original prompt pre-filled
    showSetupScreen();
    $melker.getElementById('setup-prompt').props.value = prompt;
    $melker.render();
    // Auto-start the game creation
    await startGame();
  } catch (e) {
    logger.error('Failed to clone game ' + id + ': ' + e.message);
  }
}

export function newGame() {
  showSetupScreen();
  // Show back button if there are saved games
  const backBtn = $melker.getElementById('back-to-games');
  backBtn.props.style = { ...backBtn.props.style, display: gamesIndex.length > 0 ? 'flex' : 'none' };
}

export function showSavedGames() {
  showSelectScreen();
  $melker.render();
}

// --- Logging ---

const logger = $melker.logger;

function log(containerId, msg, noTimestamp) {
  logger.info('' + msg);
  const container = $melker.getElementById(containerId);
  container.props.style = { ...container.props.style, display: 'flex' };
  const prefix = noTimestamp ? '' : '[' + new Date().toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) + '] ';
  const line = $melker.createElement('text', { text: prefix + msg });
  container.children.push(line);
  $melker.render();
  try { $melker.engine.scrollToBottom(containerId); } catch (_) {}
}

function clearLog(containerId) {
  const container = $melker.getElementById(containerId);
  container.children = [];
  container.props.style = { ...container.props.style, display: 'none' };
}

// 15x5 dark placeholder for shader base
const PLACEHOLDER_IMG = 'data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAA8AAAAFCAIAAAAVLyF7AAAAD0lEQVR4nGMQIAUwDFHVAFJwDhGYkmbYAAAAAElFTkSuQmCC';

// --- Setup ---

export async function generateGenre(genre) {
  const prompt = $melker.getElementById('setup-prompt');
  prompt.props.value = 'Generating ' + genre + ' concept...';
  $melker.render();
  try {
    const seed = Math.random().toString(36).slice(2) + Math.random().toString(36).slice(2);
    const result = await callOpenRouter(
      'Given a genre, generate a one-sentence text adventure concept in this exact style: "A [adjective] [genre] adventure in [specific setting]. Tone: [tone descriptor]." The tone MUST match the genre. Do NOT default to dark or gritty. NEVER use these overused words: witty, charming, whimsical, playful, quirky, delightful. NEVER use these overused settings: laundromat, bookshop, bakery, coffee shop, library. Find more specific, evocative descriptors and unexpected locations. Be creative, surprising, and specific with the setting. Each response must be completely different. Variation seed: ' + seed + '. Respond with ONLY the single sentence.',
      [{ role: 'user', content: genre }],
      'openai/gpt-4.1-mini'
    );
    prompt.props.value = result.trim();
    onPromptChange();
  } catch (e) {
    prompt.props.value = '';
    showError('setup-error', 'Failed to generate concept: ' + e.message);
  }
  $melker.render();
}

export function clearPrompt() {
  $melker.getElementById('setup-prompt').props.value = '';
  $melker.getElementById('restyle-row').props.style = { visibility: 'hidden', flexDirection: 'row', gap: 2, justifyContent: 'center' };
}

export function onPromptChange() {
  const val = $melker.getElementById('setup-prompt').props.value || '';
  const show = val.trim().length >= 3;
  $melker.getElementById('restyle-row').props.style = { visibility: show ? 'visible' : 'hidden', flexDirection: 'row', gap: 2, justifyContent: 'center' };
}

export async function restylePrompt(direction) {
  const prompt = $melker.getElementById('setup-prompt');
  const text = prompt.props.value;
  if (!text || text.trim().length < 3) return;
  prompt.props.value = 'Restyling...';
  $melker.render();
  try {
    const seed = Math.random().toString(36).slice(2) + Math.random().toString(36).slice(2);
    const result = await callOpenRouter(
      'You are given a text adventure story prompt. Restyle it to be ' + direction + '. Keep the core storyline and characters but change the tone and atmosphere. Output ONLY the restyled prompt, nothing else. Keep it the same length as the original. Variation seed: ' + seed + '.',
      [{ role: 'user', content: text }],
      model
    );
    prompt.props.value = result.trim();
  } catch (e) {
    prompt.props.value = text;
    $melker.toast.show('Restyle failed: ' + e.message, { type: 'error' });
  }
  $melker.render();
}

export function openFilePicker() {
  $melker.getElementById('file-dialog').props.open = true;
}

export function closeFilePicker() {
  $melker.getElementById('file-dialog').props.open = false;
}

export async function handleFileSelect(event) {
  closeFilePicker();
  const filePath = event.path;
  if (!filePath) return;
  try {
    const content = await Deno.readTextFile(filePath);
    $melker.getElementById('setup-prompt').props.value = content.trim();
    logger.info('Loaded story from ' + filePath + ' (' + content.length + ' chars)');
  } catch (e) {
    showError('setup-error', 'Failed to read file: ' + e.message);
  }
}

export async function startGame() {
  const promptInput = $melker.getElementById('setup-prompt');
  const storyPrompt = promptInput.props.value;
  if (!storyPrompt || !storyPrompt.trim()) {
    showError('setup-error', 'Enter a story prompt first.');
    return;
  }

  const logId = 'setup-log';
  clearLog(logId);
  setSpinner('setup-spinner', true);

  try {
    log(logId, 'Generating world via ' + setupModel + '...');
    const t0 = Date.now();

    // Stream world creation for progressive feedback
    const logged = {};
    const worldConfig = await callOpenRouterStreamingWithModel(
      SETUP_SYSTEM_PROMPT,
      [{ role: 'user', content: storyPrompt.trim() }],
      setupModel,
      (partial) => {
        const L = (msg) => log(logId, msg, true);
        if (!logged.title) {
          const v = extractJsonString(partial, 'title');
          if (v) { logged.title = true; L('Title: "' + v + '"'); }
        }
        if (!logged.tone) {
          const v = extractJsonString(partial, 'tone');
          if (v) { logged.tone = true; L('Tone: ' + v); }
        }
        if (!logged.setting) {
          const v = extractJsonString(partial, 'setting');
          if (v) { logged.setting = true; L('Setting: ' + v.slice(0, 80) + '...'); }
        }
        // Extract protagonist name
        const protIdx = partial.indexOf('"protagonist"');
        if (!logged.protagonist && protIdx !== -1) {
          const protName = extractJsonString(partial.slice(protIdx), 'name');
          if (protName) { logged.protagonist = true; L('Protagonist: ' + protName); }
        }
        // Extract character names from characters section only
        const charIdx = partial.indexOf('"characters"');
        const threadIdx = partial.indexOf('"threads"');
        if (charIdx !== -1) {
          const charSection = threadIdx !== -1 ? partial.slice(charIdx, threadIdx) : partial.slice(charIdx);
          const nameMatches = charSection.match(/"name"\s*:\s*"([^"]+)"/g);
          if (nameMatches) {
            for (let i = 0; i < nameMatches.length; i++) {
              if (!logged['char_' + i]) {
                logged['char_' + i] = true;
                const name = nameMatches[i].match(/"name"\s*:\s*"([^"]+)"/)[1];
                L('Character: ' + name);
              }
            }
          }
        }
        // Extract thread names from threads section only
        if (threadIdx !== -1) {
          const sysIdx = partial.indexOf('"narratorPrompt"');
          const threadSection = sysIdx !== -1 ? partial.slice(threadIdx, sysIdx) : partial.slice(threadIdx);
          const threadMatches = threadSection.match(/"name"\s*:\s*"([^"]+)"/g);
          if (threadMatches) {
            for (let i = 0; i < threadMatches.length; i++) {
              if (!logged['thread_' + i]) {
                logged['thread_' + i] = true;
                const name = threadMatches[i].match(/"name"\s*:\s*"([^"]+)"/)[1];
                L('Thread: ' + name);
              }
            }
          }
        }
        // Detect narratorPrompt generation started
        if (!logged.sysPrompt && partial.includes('"narratorPrompt"')) {
          logged.sysPrompt = true;
          L('Generating narrator voice...');
        }
      }
    );
    log(logId, 'World config received (' + ((Date.now() - t0) / 1000).toFixed(1) + 's)' + usageSuffix());

    const config = parseJSON(worldConfig);
    if (!config || !config.title || !config.narratorPrompt) {
      showError('setup-error', 'Failed to generate world. Try again with a different prompt.');
      setSpinner('setup-spinner', false);
      return;
    }

    // Store only the creative narrator voice; TURN_RULES are injected at turn time
    // so that rule updates apply to saved games too
    config.systemPrompt = config.narratorPrompt;

    log(logId, 'World: "' + config.title + '"');
    log(logId, (config.locations?.length || 0) + ' locations, ' + (config.characters?.length || 0) + ' characters, ' + (config.threads?.length || 0) + ' threads');
    if (config.imageConstraints) log(logId, 'Custom image constraints: ' + config.imageConstraints);
    logger.info('World config: ' + JSON.stringify(config));
    logger.info('System prompt: ' + config.systemPrompt);

    currentGameId = generateGameId();
    // Seed initial facts from world config
    const initialFacts = {};
    if (config.protagonist?.appearance) {
      initialFacts['appearance:' + (config.protagonist.name || 'protagonist').toLowerCase()] = config.protagonist.appearance;
    }
    if (config.characters) {
      for (const c of config.characters) {
        if (c.name && c.appearance) initialFacts['appearance:' + c.name.toLowerCase()] = c.appearance;
        if (c.name && c.motivation) initialFacts['npc:' + c.name.toLowerCase() + ':motivation'] = c.motivation;
      }
    }
    if (config.threads) {
      for (const t of config.threads) {
        if (t.name) initialFacts['thread:' + t.name.toLowerCase()] = t.description || 'introduced';
      }
    }
    gameState = {
      worldConfig: config,
      storyPrompt: storyPrompt.trim(),
      history: [],
      currentScene: '',
      turnCount: 0,
      inventory: [],
      location: config.locations?.[0] || 'Unknown',
      choices: [],
      facts: initialFacts
    };
    currentImage = null;

    // Add to games index
    gamesIndex.push({
      id: currentGameId,
      title: config.title,
      turnCount: 0,
      location: gameState.location,
      lastPlayed: new Date().toISOString()
    });
    await saveGamesIndex();

    // Clear previous game's image and text before showing game screen
    const imgEl = $melker.getElementById('scene-image');
    imgEl.setSrc(PLACEHOLDER_IMG);
    setImageLoading(true);
    $melker.getElementById('narrative').props.text = '*Generating opening scene...*';
    $melker.getElementById('choices-bar').children = [];
    renderScene();
    showGameScreen();
    focusInput();
    $melker.render();
    log('log-area', 'Generating opening scene via ' + model + '...');
    const t1 = Date.now();
    const opening = await callOpenRouterStreaming(
      config.systemPrompt + '\n\n' + TURN_RULES,
      [{ role: 'user', content: 'Begin the adventure. Describe the opening scene.' }]
    );
    log(logId, 'Opening scene received (' + ((Date.now() - t1) / 1000).toFixed(1) + 's)' + usageSuffix());

    const scene = parseJSON(opening);
    if (scene) {
      applyScene(scene);
      gameState.history.push(
        { role: 'user', content: 'Begin the adventure. Describe the opening scene.' },
        { role: 'assistant', content: opening }
      );
    } else {
      gameState.currentScene = opening;
    }

    // Show narrative and choices while image generates
    renderScene();
    $melker.render();

    // Generate opening image
    await generateSceneImage(logId);

    await saveState();
    log(logId, 'Game state saved. Starting adventure!');

    renderScene();
    $melker.render();
    clearLog(logId);
    focusInput();
  } catch (e) {
    showError('setup-error', 'Error: ' + e.message);
    log(logId, 'ERROR: ' + e.message);
  }

  setSpinner('setup-spinner', false);
  setSpinner('game-spinner', false);
}

// --- Gameplay ---

export async function handleInput() {
  const input = $melker.getElementById('cmd-input');
  const text = input.props.value;
  if (!text || !text.trim()) return;
  input.props.value = '';

  const cmd = text.trim();
  const logId = 'log-area';

  // Local commands
  if (cmd === '/new') {
    gameState = null;
    currentGameId = null;
    currentImage = null;
    setMoodShader(null, true);
    showSetupScreen();
    return;
  }
  if (cmd === '/games') {
    gameState = null;
    currentGameId = null;
    currentImage = null;
    setMoodShader(null, true);
    showSelectScreen();
    $melker.render();
    return;
  }
  if (cmd === '/help') {
    $melker.getElementById('help-dialog').props.open = true;
    return;
  }
  if (cmd === '/undo') {
    if (gameState.history.length >= 2) {
      // Cancel any in-flight image generation for the turn being undone
      if (imageAbort) { imageAbort.abort(); imageAbort = null; }
      // Save undone pair + current facts snapshot to redo stack
      const assistant = gameState.history.pop();
      const user = gameState.history.pop();
      const factsSnapshot = JSON.parse(JSON.stringify(gameState.facts || {}));
      redoStack.push({ user, assistant, facts: factsSnapshot });
      gameState.turnCount = Math.max(0, gameState.turnCount - 1);
      // Replay last assistant response to restore scene (and its stateUpdates)
      // First reset facts to what they were before the undone turn by re-applying all history
      gameState.facts = rebuildFacts(gameState);
      const lastAssistant = gameState.history.length > 0
        ? gameState.history[gameState.history.length - 1]
        : null;
      if (lastAssistant && lastAssistant.role === 'assistant') {
        const scene = parseJSON(lastAssistant.content);
        if (scene) {
          // Apply scene without stateUpdates (facts already rebuilt)
          if (scene.narrative) gameState.currentScene = scene.narrative;
          if (scene.location) gameState.location = scene.location;
          if (scene.inventory) gameState.inventory = scene.inventory;
          if (scene.choices) gameState.choices = scene.choices.map(c => typeof c === 'string' ? c : (c.label || c.text || String(c)));
          gameState.sceneImagePrompt = scene.imagePrompt || null;
          gameState._lastSceneImageStyle = scene.imageStyle || null;
          gameState.mood = scene.mood || null;
          setMoodShader(gameState.mood, true);
        } else {
          gameState.currentScene = lastAssistant.content;
          gameState.mood = null;
          setMoodShader(null, true);
        }
      } else {
        gameState.currentScene = '*Back to the beginning...*';
        gameState.choices = [];
        gameState.sceneImagePrompt = null;
        gameState.mood = null;
        setMoodShader(null, true);
      }
      // Restore cached image for this turn (clear first to avoid stale image)
      currentImage = null;
      const imgKey = currentGameId ? 'image:' + currentGameId + ':' + gameState.turnCount : 'image:' + gameState.turnCount;
      const cachedImg = await $melker.cache.read(CACHE_NS, imgKey);
      if (cachedImg) {
        currentImage = decoder.decode(cachedImg);
      }
      await saveState();
      renderScene();
      log(logId, 'Undid last turn. Now at turn ' + gameState.turnCount + (redoStack.length ? ' (/redo available)' : ''));
    } else {
      $melker.toast.show('Nothing to undo', { type: 'warning' });
    }
    return;
  }
  if (cmd === '/redo') {
    if (redoStack.length > 0) {
      const entry = redoStack.pop();
      gameState.history.push(entry.user, entry.assistant);
      gameState.turnCount++;
      // Restore the facts snapshot from when this turn was active
      if (entry.facts) gameState.facts = entry.facts;
      const scene = parseJSON(entry.assistant.content);
      if (scene) {
        // Apply scene without stateUpdates (facts already restored from snapshot)
        if (scene.narrative) gameState.currentScene = scene.narrative;
        if (scene.location) gameState.location = scene.location;
        if (scene.inventory) gameState.inventory = scene.inventory;
        if (scene.choices) gameState.choices = scene.choices.map(c => typeof c === 'string' ? c : (c.label || c.text || String(c)));
        gameState.sceneImagePrompt = scene.imagePrompt || null;
        gameState._lastSceneImageStyle = scene.imageStyle || null;
        gameState.mood = scene.mood || null;
        setMoodShader(gameState.mood, true);
      } else {
        gameState.currentScene = entry.assistant.content;
        gameState.mood = null;
        setMoodShader(null, true);
      }
      // Restore cached image for this turn
      currentImage = null;
      const imgKey = currentGameId ? 'image:' + currentGameId + ':' + gameState.turnCount : 'image:' + gameState.turnCount;
      const cachedImg = await $melker.cache.read(CACHE_NS, imgKey);
      if (cachedImg) {
        currentImage = decoder.decode(cachedImg);
      }
      await saveState();
      renderScene();
      log(logId, 'Redid turn ' + gameState.turnCount);
    } else {
      $melker.toast.show('Nothing to redo', { type: 'warning' });
    }
    return;
  }
  if (cmd === '/image') {
    if (currentImage) {
      try {
        // Extract image data and write to temp file
        const dataUrl = currentImage;
        const mimeMatch = dataUrl.match(/^data:(image\/\w+);base64,/);
        const ext = mimeMatch ? mimeMatch[1].split('/')[1] : 'png';
        const b64 = dataUrl.replace(/^data:image\/\w+;base64,/, '');
        const bytes = Uint8Array.from(atob(b64), c => c.charCodeAt(0));
        const tmpPath = $melker.cacheDir + '/scene.' + ext;
        await Deno.writeFile(tmpPath, bytes);
        $melker.openBrowser(tmpPath);
        log(logId, 'Opened image in browser: ' + tmpPath);
      } catch (e) {
        $melker.toast.show('Failed to open image: ' + e.message, { type: 'error' });
      }
    } else {
      $melker.toast.show('No scene image available', { type: 'warning' });
    }
    return;
  }
  if (cmd === '/images') {
    skipImages = !skipImages;
    $melker.toast.show('Image generation ' + (skipImages ? 'OFF' : 'ON'));
    return;
  }
  if (cmd === '/reimage' || cmd.startsWith('/reimage ')) {
    clearLog(logId);
    const customStyle = cmd.slice(8).trim() || null;
    await generateSceneImage(logId, customStyle);
    setSpinner('game-spinner', false);
    renderScene();
    $melker.render();
    return;
  }
  if (cmd.startsWith('/gfx')) {
    const arg = cmd.slice(4).trim();
    const imgEl = $melker.getElementById('scene-image');
    if (arg === 'reset' || !arg) {
      gfxModeIndex = 0;
      imgEl.props.gfxMode = undefined;
      log(logId, 'GFX mode: reset to default');
    } else if (GFX_MODES.includes(arg)) {
      gfxModeIndex = GFX_MODES.indexOf(arg);
      imgEl.props.gfxMode = arg;
      log(logId, 'GFX mode: ' + arg);
    } else {
      $melker.toast.show('Unknown gfx mode. Options: ' + GFX_MODES.join(', ') + ', reset', { type: 'warning' });
    }
    $melker.engine.requestForceRender();
    return;
  }
  if (cmd.startsWith('/dither')) {
    const arg = cmd.slice(7).trim();
    const imgEl = $melker.getElementById('scene-image');
    if (arg === 'reset' || !arg) {
      ditherBitsIndex = 2;
      imgEl.props.ditherBits = undefined;
      imgEl.props.dither = 'sierra-stable';
      log(logId, 'Dither: reset to default');
    } else {
      const bits = parseInt(arg);
      if (DITHER_BITS.includes(bits)) {
        ditherBitsIndex = DITHER_BITS.indexOf(bits);
        imgEl.props.ditherBits = bits;
        log(logId, 'Dither bits: ' + bits);
      } else {
        $melker.toast.show('Unknown dither bits. Options: ' + DITHER_BITS.join(', ') + ', reset', { type: 'warning' });
      }
    }
    $melker.engine.requestForceRender();
    return;
  }
  if (cmd === '/state') {
    const facts = gameState.facts || {};
    const entries = Object.entries(facts);
    if (entries.length === 0) {
      $melker.toast.show('No world facts recorded yet', { type: 'info' });
      return;
    }
    const lines = ['## World State (' + entries.length + ' facts)', ''];
    for (const [k, v] of entries.sort((a, b) => a[0].localeCompare(b[0]))) {
      lines.push('- **' + k + '**: ' + v);
    }
    lines.push('', '---', '', gameState.currentScene);
    gameState.currentScene = lines.join('\n');
    renderScene();
    return;
  }
  if (cmd === '/history') {
    const lines = ['## Recent History', ''];
    const recent = gameState.history.slice(-10);
    for (const entry of recent) {
      if (entry.role === 'user') {
        lines.push('**> ' + entry.content + '**');
      } else {
        const parsed = parseJSON(entry.content);
        lines.push((parsed ? parsed.narrative : entry.content).slice(0, 100) + '...');
      }
      lines.push('');
    }
    lines.push('---', '', gameState.currentScene);
    gameState.currentScene = lines.join('\n');
    renderScene();
    return;
  }
  if (cmd === '/story') {
    try {
      const title = gameState.worldConfig?.title || 'Untitled';
      const htmlParts = [];
      htmlParts.push('<!DOCTYPE html><html><head><meta charset="utf-8">');
      htmlParts.push('<title>' + title + '</title>');
      htmlParts.push('<style>');
      htmlParts.push('body{max-width:720px;margin:0 auto;padding:2em;font-family:Georgia,serif;background:#111;color:#ddd;line-height:1.7}');
      htmlParts.push('h1{text-align:center;color:#e8c56d;border-bottom:2px solid #333;padding-bottom:0.5em}');
      htmlParts.push('h3{color:#b8a040;margin-top:2em}');
      htmlParts.push('.location{color:#888;font-style:italic;margin-bottom:0.5em}');
      htmlParts.push('.action{background:#1a1a2a;border-left:3px solid #556;padding:0.5em 1em;margin:1em 0;color:#aab}');
      htmlParts.push('img{width:100%;border-radius:6px;margin:0.5em 0}');
      htmlParts.push('hr{border:none;border-top:1px solid #333;margin:2em 0}');
      htmlParts.push('</style></head><body>');
      htmlParts.push('<h1>' + title + '</h1>');
      let turnNum = -1;
      for (let i = 0; i < gameState.history.length; i++) {
        const entry = gameState.history[i];
        if (entry.role === 'assistant') {
          turnNum++;
          const parsed = parseJSON(entry.content);
          const narrative = parsed ? parsed.narrative : entry.content;
          const imgKey = currentGameId ? 'image:' + currentGameId + ':' + turnNum : 'image:' + turnNum;
          const cachedImg = await $melker.cache.read(CACHE_NS, imgKey);
          const label = turnNum === 0 ? 'Prologue' : 'Turn ' + turnNum;
          htmlParts.push('<hr><h3>' + label + '</h3>');
          if (parsed?.location) htmlParts.push('<div class="location">' + parsed.location + '</div>');
          if (cachedImg) htmlParts.push('<img src="' + decoder.decode(cachedImg) + '">');
          htmlParts.push('<p>' + (narrative || '').replace(/\n/g, '</p><p>') + '</p>');
        } else if (entry.role === 'user') {
          const actionMatch = entry.content.match(/<ACTION>([\s\S]*?)<\/ACTION>/);
          const action = actionMatch ? actionMatch[1].trim() : entry.content;
          if (turnNum >= 0) htmlParts.push('<div class="action">' + action + '</div>');
        }
      }
      // Append current turn if not already in history
      if (gameState.currentScene && turnNum < gameState.turnCount) {
        turnNum = gameState.turnCount;
        const imgKey = currentGameId ? 'image:' + currentGameId + ':' + turnNum : 'image:' + turnNum;
        const cachedImg = await $melker.cache.read(CACHE_NS, imgKey);
        htmlParts.push('<hr><h3>Turn ' + turnNum + '</h3>');
        if (gameState.location) htmlParts.push('<div class="location">' + gameState.location + '</div>');
        if (cachedImg) htmlParts.push('<img src="' + decoder.decode(cachedImg) + '">');
        else if (currentImage) htmlParts.push('<img src="' + currentImage + '">');
        htmlParts.push('<p>' + gameState.currentScene.replace(/\n/g, '</p><p>') + '</p>');
      }
      htmlParts.push('</body></html>');
      const storyPath = $melker.cacheDir + '/story.html';
      await Deno.writeTextFile(storyPath, htmlParts.join('\n'));
      $melker.openBrowser(storyPath);
      log(logId, 'Story opened in browser (' + turnNum + ' turns)');
    } catch (e) {
      $melker.toast.show('Failed to generate story: ' + e.message, { type: 'error' });
    }
    return;
  }

  if (cmd.startsWith('/mood')) {
    const args = cmd.slice(5).trim().toLowerCase().split(/[\s,+]+/).filter(Boolean);
    if (!args.length || args[0] === 'off' || args[0] === 'none') {
      setMoodShader(null);
      log(logId, 'Mood off');
    } else {
      const valid = args.filter(n => MOOD_SHADERS[n]).slice(0, 2);
      if (valid.length) {
        setMoodShader(valid, true);
        log(logId, 'Mood: ' + valid.join(' + '));
      } else {
        log(logId, 'Available: ' + Object.keys(MOOD_SHADERS).join(', '));
      }
    }
    return;
  }

  if (cmd === '/cost' || cmd === '/cost on' || cmd === '/cost off') {
    const bar = $melker.getElementById('cost-bar');
    const on = cmd === '/cost' ? bar.props.style?.display === 'none' : cmd === '/cost on';
    bar.props.style = { ...bar.props.style, display: on ? 'flex' : 'none' };
    if (on) updateCostBar();
    log(logId, 'Cost display ' + (on ? 'on' : 'off'));
    return;
  }

  // Unknown / commands — don't send to AI
  if (cmd.startsWith('/')) {
    $melker.toast.show('Unknown command: ' + cmd, { type: 'warning' });
    return;
  }

  // Prevent concurrent AI turns
  if (turnBusy) {
    $melker.toast.show('Wait for the current turn to finish', { type: 'warning' });
    return;
  }

  // Cancel any in-flight image generation
  if (imageAbort) {
    imageAbort.abort();
    imageAbort = null;
  }

  // AI turn — new action invalidates redo history
  redoStack = [];
  turnBusy = true;
  clearLog(logId);
  setSpinner('game-spinner', true);
  setImageLoading(true);

  try {
    // Wrap user input with game state context
    // Cap facts sent to LLM: prioritize appearance/thread/npc, then freeform up to MAX_FACTS
    const MAX_FACTS = 100;
    const allFacts = Object.entries(gameState.facts || {});
    let factsForPrompt = allFacts;
    if (allFacts.length > MAX_FACTS) {
      const priority = allFacts.filter(([k]) => k.startsWith('appearance:') || k.startsWith('thread:') || k.startsWith('npc:'));
      const rest = allFacts.filter(([k]) => !k.startsWith('appearance:') && !k.startsWith('thread:') && !k.startsWith('npc:'));
      factsForPrompt = [...priority, ...rest.slice(-(MAX_FACTS - priority.length))];
      logger.warn('Facts capped: ' + allFacts.length + ' total, sending ' + factsForPrompt.length + ' (dropped ' + (allFacts.length - factsForPrompt.length) + ' low-priority)');
    }
    const factsBlock = factsForPrompt.length > 0
      ? '<FACTS>\n' + factsForPrompt.map(([k, v]) => k + '=' + v).join('\n') + '\n</FACTS>\n'
      : '';
    const userMsg = '<STATE>\n'
      + '<LOCATION>' + gameState.location + '</LOCATION>\n'
      + '<INVENTORY>' + (gameState.inventory.length ? gameState.inventory.join(', ') : 'empty') + '</INVENTORY>\n'
      + '<TURN>' + gameState.turnCount + '</TURN>\n'
      + factsBlock
      + '</STATE>\n'
      + '<ACTION>' + cmd + '</ACTION>';
    gameState.history.push({ role: 'user', content: userMsg });

    // Prune history — snapshot facts first so rebuildFacts can start from checkpoint
    if (gameState.history.length > MAX_HISTORY * 2) {
      gameState.factsCheckpoint = JSON.parse(JSON.stringify(gameState.facts || {}));
      gameState.history = gameState.history.slice(-MAX_HISTORY * 2);
    }

    log(logId, 'Sending to ' + model + ' (' + gameState.history.length + ' messages in context)...');
    const t0 = Date.now();

    const response = await callOpenRouterStreaming(
      gameState.worldConfig.systemPrompt + '\n\n' + TURN_RULES,
      gameState.history
    );

    const elapsed = ((Date.now() - t0) / 1000).toFixed(1);
    log(logId, 'Response received (' + elapsed + 's)' + usageSuffix());

    gameState.history.push({ role: 'assistant', content: response });
    gameState.turnCount++;
    logger.info('Turn response: ' + response);

    const scene = parseJSON(response);
    if (scene) {
      applyScene(scene);
      renderScene();
      $melker.render();
      log(logId, 'Location: ' + (scene.location || gameState.location));
    } else {
      gameState.currentScene = response;
      renderScene();
      $melker.render();
      log(logId, 'Raw text response (no structured JSON)');
    }

    // Save state immediately so fast-clicking doesn't lose turns
    await saveState();

    // Release turn lock — player can input next turn while image generates
    turnBusy = false;
    focusInput();

    // Delay image generation 2s so player can quickly send next action to skip it
    await new Promise(r => setTimeout(r, 2000));
    if (turnBusy) return; // player already started next turn
    // Generate scene image in background (abortable by next turn)
    await generateSceneImage(logId);

    if (gameState) {
      await saveState(); // re-save with cached image key
      log(logId, 'Turn ' + gameState.turnCount + ' complete.');
      renderScene();
    }
  } catch (e) {
    if (gameState) {
      gameState.currentScene += '\n\n*Error: ' + e.message + '*';
      gameState.history.pop();
      renderScene();
    }
    log(logId, 'ERROR: ' + e.message);
  }

  turnBusy = false;
  setSpinner('game-spinner', false);
  setImageLoading(false);
  $melker.render();
  focusInput();
}

// Rebuild facts by seeding from worldConfig and replaying all stateUpdates in history
function rebuildFacts(state) {
  let facts;
  if (state.factsCheckpoint) {
    // Start from checkpoint (taken before history pruning) instead of replaying pruned entries
    facts = JSON.parse(JSON.stringify(state.factsCheckpoint));
  } else {
    // No checkpoint — seed from worldConfig
    facts = {};
    const wc = state.worldConfig || {};
    if (wc.protagonist?.appearance) {
      facts['appearance:' + (wc.protagonist.name || 'protagonist').toLowerCase()] = wc.protagonist.appearance;
    }
    if (wc.characters) {
      for (const c of wc.characters) {
        if (c.name && c.appearance) facts['appearance:' + c.name.toLowerCase()] = c.appearance;
        if (c.name && c.motivation) facts['npc:' + c.name.toLowerCase() + ':motivation'] = c.motivation;
      }
    }
    if (wc.threads) {
      for (const t of wc.threads) {
        if (t.name) facts['thread:' + t.name.toLowerCase()] = t.description || 'introduced';
      }
    }
  }
  // Replay stateUpdates from all assistant messages
  for (const entry of (state.history || [])) {
    if (entry.role !== 'assistant') continue;
    const scene = parseJSON(entry.content);
    if (!scene?.stateUpdates) continue;
    for (const su of scene.stateUpdates) {
      if (su.delete) delete facts[String(su.delete).toLowerCase()];
      else if (su.set && su.value !== undefined) facts[String(su.set).toLowerCase()] = String(su.value);
    }
  }
  return facts;
}

function applyScene(scene) {
  if (scene.narrative) gameState.currentScene = scene.narrative;
  if (scene.location) gameState.location = scene.location;
  if (scene.inventory) gameState.inventory = scene.inventory;
  if (scene.choices) gameState.choices = scene.choices.map(c => typeof c === 'string' ? c : (c.label || c.text || String(c)));
  // LLM-generated image prompt for this scene
  gameState.sceneImagePrompt = scene.imagePrompt || null;
  // Per-scene image style override (cleared each turn, only set if model provides one)
  gameState._lastSceneImageStyle = scene.imageStyle || null;
  if (scene.imageStyle) logger.info('Scene image style override: ' + scene.imageStyle);
  // Mood shader(s) — triggered by "mood" field from narrator (string or array)
  gameState.mood = scene.mood || null;
  setMoodShader(gameState.mood);
  logger.debug('Scene applied | location=' + gameState.location + ' inventory=[' + gameState.inventory.join(', ') + '] choices=' + (gameState.choices?.length || 0) + ' narrative=' + (gameState.currentScene?.length || 0) + ' chars');
  // Apply state updates (facts) — all keys normalized to lowercase
  if (scene.stateUpdates && Array.isArray(scene.stateUpdates)) {
    if (!gameState.facts) gameState.facts = {};
    for (const su of scene.stateUpdates) {
      if (su.delete) {
        const key = String(su.delete).toLowerCase();
        delete gameState.facts[key];
        logger.debug('Fact deleted: ' + key);
      } else if (su.set && su.value !== undefined) {
        const key = String(su.set).toLowerCase();
        gameState.facts[key] = String(su.value);
        logger.debug('Fact set: ' + key + ' = ' + su.value);
        // Log notable fact changes to the player
        if (key.startsWith('thread:')) {
          log('log-area', 'Thread [' + key.slice(7) + '] ' + su.value, true);
        } else if (key.startsWith('appearance:')) {
          log('log-area', key.slice(11) + ' appearance changed', true);
        }
      }
    }
    logger.info('State updates applied: ' + JSON.stringify(scene.stateUpdates));
    // Warn if facts are getting large
    const factCount = Object.keys(gameState.facts).length;
    if (factCount > 80) {
      logger.warn('Facts store has ' + factCount + ' entries — consider pruning');
    }
  }
}

// --- Image GFX Controls ---

const GFX_MODES = ['sextant', 'halfblock', 'quadrant', 'pattern', 'luma'];
const DITHER_BITS = [1, 2, 4, 8];
let gfxModeIndex = 0;
let ditherBitsIndex = 2; // default 8

let imageClickAbort = null;

export async function handleImageClick(event) {
  // Clear fisheye on click, keep mood if active
  if (fisheyeActive) {
    fisheyeActive = false;
    updateShaderPipeline();
  }
  const imgEl = $melker.getElementById('scene-image');
  const pos = event.position || {};
  const clickX = pos.x || 0;
  const clickY = pos.y || 0;
  const layout = imgEl.getLayout?.() || {};
  const w = layout.width || 80;
  const h = layout.height || 24;
  const logId = 'log-area';

  // Modifier+click: cycle gfx mode / dither bits
  if (event.shiftKey || event.ctrlKey || event.altKey) {
    if (clickX < w / 2) {
      gfxModeIndex = (gfxModeIndex + 1) % GFX_MODES.length;
      imgEl.props.gfxMode = GFX_MODES[gfxModeIndex];
      log(logId, 'GFX mode: ' + GFX_MODES[gfxModeIndex]);
    } else {
      ditherBitsIndex = (ditherBitsIndex + 1) % DITHER_BITS.length;
      imgEl.props.ditherBits = DITHER_BITS[ditherBitsIndex];
      log(logId, 'Dither bits: ' + DITHER_BITS[ditherBitsIndex]);
    }
    $melker.engine.requestForceRender();
    return;
  }

  if (!currentImage || !gameState || turnBusy) return;
  if (!visionModel) return;

  // Normalize click to percentage of image
  const pctX = Math.round((clickX / w) * 100);
  const pctY = Math.round((clickY / h) * 100);
  logger.info('Image click at (' + pctX + '%,' + pctY + '%) of image');

  // Cancel any pending analysis
  if (imageClickAbort) {
    imageClickAbort.abort();
    imageClickAbort = null;
  }

  const spinner = $melker.getElementById('game-spinner');
  spinner.props.spinning = true;
  spinner.props.verbs = 'analyzing';
  spinner.props.style = { ...spinner.props.style, visibility: 'visible' };
  imageClickAbort = new AbortController();

  try {
    const sceneDesc = gameState.sceneImagePrompt || gameState.currentScene || '';
    const facts = Object.entries(gameState.facts || {})
      .filter(([k]) => k.startsWith('appearance:') || k.startsWith('location:') || k.startsWith('npc:'))
      .map(([k, v]) => k + '=' + v)
      .join('\n');

    const analysisPrompt = 'This is a scene from a text adventure game. The player clicked at approximately '
      + pctX + '% from the left and ' + pctY + '% from the top of the image.\n\n'
      + 'Scene context: ' + sceneDesc + '\n'
      + (facts ? 'Known facts:\n' + facts + '\n' : '')
      + '\nIdentify what the player clicked on. Respond with a JSON object:\n'
      + '{"target": "<what was clicked, e.g. a door, a character, an object>", "action": "<a natural player action, e.g. examine the rusty door, talk to the merchant, pick up the key>"}\n'
      + 'If the click is on empty space or background with nothing notable, respond: {"target": null, "action": null}';

    const res = await fetch('https://openrouter.ai/api/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + apiKey,
        'HTTP-Referer': 'https://melker.sh',
        'X-Title': 'Melkrox'
      },
      body: JSON.stringify({
        model: visionModel,
        messages: [{
          role: 'user',
          content: [
            { type: 'text', text: analysisPrompt },
            { type: 'image_url', image_url: { url: currentImage } }
          ]
        }],
        temperature: 0.3,
        max_tokens: 256
      }),
      signal: imageClickAbort.signal
    });

    if (!res.ok) {
      const text = await res.text();
      logger.error('Vision API error ' + res.status + ': ' + text.slice(0, 200));
      $melker.toast.show('Vision analysis failed', { type: 'error' });
      return;
    }

    const json = await res.json();
    const content = json.choices?.[0]?.message?.content || '';
    logger.info('Vision analysis: ' + content);

    const parsed = parseJSON(content);
    if (parsed && parsed.target && parsed.action) {
      // Feed the analysis as a player action
      const input = $melker.getElementById('cmd-input');
      input.props.value = parsed.action;
      log(logId, 'Click: ' + parsed.target);
      $melker.render();
    } else {
      log(logId, 'Nothing notable there');
    }
  } catch (e) {
    if (e.name !== 'AbortError') {
      logger.error('Vision click error: ' + e.message);
      $melker.toast.show('Analysis failed: ' + e.message, { type: 'error' });
    }
  } finally {
    imageClickAbort = null;
    const spinner = $melker.getElementById('game-spinner');
    spinner.stop();
    spinner.props.style = { ...spinner.props.style, visibility: 'hidden' };
    // Re-activate fisheye if mouse is still over the image
    if (mouseOverImage && !fisheyeActive && currentImage) {
      fisheyeActive = true;
      updateShaderPipeline();
    }
    $melker.render();
  }
}

// --- Image Loading Shader ---

let shaderTint = null; // cached color sample from first frame

export function loadingShader(x, y, time, resolution, source, utils) {
  const pixel = source?.getPixel(x, y);
  if (!pixel) return [0, 0, 0];
  const [r, g, b] = pixel;
  // Sample representative pixels only on first frame
  if (!shaderTint) {
    const w = resolution.width;
    const h = resolution.height;
    const s1 = source.getPixel(Math.floor(w * 0.25), Math.floor(h * 0.5)) || [0, 0, 0];
    const s2 = source.getPixel(Math.floor(w * 0.5), Math.floor(h * 0.5)) || [0, 0, 0];
    const s3 = source.getPixel(Math.floor(w * 0.75), Math.floor(h * 0.5)) || [0, 0, 0];
    shaderTint = [
      (s1[0] + s2[0] + s3[0]) / (3 * 255),
      (s1[1] + s2[1] + s3[1]) / (3 * 255),
      (s1[2] + s2[2] + s3[2]) / (3 * 255)
    ];
  }
  const [avgR, avgG, avgB] = shaderTint;
  // Simplex noise plasma at different scales
  const n1 = utils.simplex3d(x * 0.03, y * 0.04, time * 0.6);
  const n2 = utils.simplex3d(x * 0.06 + 5, y * 0.08 + 5, time * 0.4);
  const plasma = n1 * 0.6 + n2 * 0.4;
  // Vignette — grows over time, fading sides to black
  const nx = x / resolution.width;
  const grow = Math.min(1, time * 0.08);
  const edgeL = Math.min(1, nx / (0.3 + grow * 0.2));
  const edgeR = Math.min(1, (1 - nx) / (0.3 + grow * 0.2));
  const fade = edgeL * edgeL * edgeR * edgeR;
  // Plasma tint derived from source image colors
  const boost = 0.15;
  const tintR = plasma * (avgR * 0.4 + boost) + avgR * 0.05;
  const tintG = plasma * (avgG * 0.4 + boost * 0.3) + avgG * 0.05;
  const tintB = plasma * (avgB * 0.4 + boost) + avgB * 0.05;
  // Blend image with plasma-tinted dark
  const pr = Math.round(r * fade + tintR * 255 * (1 - fade));
  const pg = Math.round(g * fade + tintG * 255 * (1 - fade));
  const pb = Math.round(b * fade + tintB * 255 * (1 - fade));
  return [Math.min(255, pr), Math.min(255, pg), Math.min(255, pb)];
}

// Pre-instantiate effect shaders from engine (factories return ShaderCallback)
const MOOD_SHADERS = {
  lightning: $melker.shaderEffects.lightning(),
  rain: $melker.shaderEffects.rain(),
  bloom: $melker.shaderEffects.bloom(),
  sunrays: $melker.shaderEffects.sunrays(),
  glitch: $melker.shaderEffects.glitch(),
  fog: $melker.shaderEffects.fog(),
  fire: $melker.shaderEffects.fire(),
  underwater: $melker.shaderEffects.underwater(),
  snow: $melker.shaderEffects.snow(),
  darkness: $melker.shaderEffects.darkness(),
  sandstorm: $melker.shaderEffects.sandstorm(),
  magic: $melker.shaderEffects.magic(),
  heat: $melker.shaderEffects.heat(),
};

const fisheyeShaderFn = $melker.shaderEffects.fisheye();

let fisheyeActive = false;
let mouseOverImage = false;
let activeMoods = []; // 0-2 mood shader names

// Fixed-slot shader pipeline: [mood1, mood2, loading, fisheye]. Null slots are no-ops.
const shaderPipeline = [null, null, null, null];

function updateShaderPipeline() {
  shaderPipeline[0] = activeMoods[0] && MOOD_SHADERS[activeMoods[0]] ? MOOD_SHADERS[activeMoods[0]] : null;
  shaderPipeline[1] = activeMoods[1] && MOOD_SHADERS[activeMoods[1]] ? MOOD_SHADERS[activeMoods[1]] : null;
  // slot [2] (loading) is managed by setImageLoading
  shaderPipeline[3] = fisheyeActive ? fisheyeShaderFn : null;
  const imgEl = $melker.getElementById('scene-image');
  imgEl.stopShader();
  imgEl.clear();
  imgEl.refreshImage();
  imgEl.props.onShader = shaderPipeline.some(s => s) ? shaderPipeline : undefined;
  imgEl.props.shaderFps = fisheyeActive ? 24 : shaderPipeline[2] ? 10 : 12;
}

function setMoodShader(moods, immediate) {
  // Normalize to array of valid mood names (max 2)
  const names = (Array.isArray(moods) ? moods : moods ? [moods] : [])
    .filter(n => n && MOOD_SHADERS[n])
    .slice(0, 2);
  activeMoods = names;
  if (names.length > 0) {
    if (immediate && currentImage) {
      updateShaderPipeline();
    }
    logger.info('Mood shaders: ' + names.join(', '));
  } else {
    updateShaderPipeline();
  }
}

export function handleImageMouseOver() {
  mouseOverImage = true;
  if (fisheyeActive) return;
  if (!currentImage) return;
  fisheyeActive = true;
  updateShaderPipeline();
}

export function handleImageMouseOut() {
  mouseOverImage = false;
  if (!fisheyeActive) return;
  fisheyeActive = false;
  updateShaderPipeline();
}

function setImageLoading(on) {
  shaderTint = null; // reset so next activation re-samples
  if (on && shaderPipeline[2] === $app.loadingShader) return; // already loading
  if (on) fisheyeActive = false; // image is changing, clear fisheye
  shaderPipeline[2] = on ? $app.loadingShader : null;
  updateShaderPipeline();
}

// --- Scene Image Generation ---

async function generateSceneImage(logId, customStyle) {
  if (!imageModel) {
    logger.debug('No image model configured, skipping image generation');
    return;
  }

  try {
    const sceneStyle = gameState._lastSceneImageStyle;
    const baseStyle = gameState.worldConfig?.imageStyle || '';
    const activeStyle = sceneStyle || baseStyle;
    const defaultConstraints = 'Wide 3:1 format. No fine detail. '
      + 'NO thin lines, NO text, NO crowds, NO intricate patterns. ';
    const constraints = customStyle
      ? customStyle
      : (gameState.worldConfig?.imageConstraints || defaultConstraints);
    // Custom style is a full override — don't append world imageStyle
    const styleBlock = customStyle
      ? constraints + '\n'
      : constraints + '\n' + (activeStyle ? activeStyle + '\n' : '');

    // Use LLM-generated image prompt if available, fall back to scene narrative
    const sceneDesc = gameState.sceneImagePrompt || gameState.currentScene || '';
    const imagePrompt = 'Generate a scene illustration.\n'
      + '<STYLE>\n'
      + styleBlock
      + '</STYLE>\n'
      + '<SCENE>' + sceneDesc + '</SCENE>';

    logger.info('Image prompt: ' + imagePrompt);

    if (skipImages) {
      log(logId, 'Image generation skipped (skipImages=true)');
      return;
    }

    log(logId, 'Generating scene image via ' + imageModel + '...');
    setSpinner('game-spinner', true, 'painting scene');

    imageAbort = new AbortController();
    const t0 = Date.now();

    const imageData = await callImageGeneration(imagePrompt, imageAbort.signal);
    imageAbort = null;

    setSpinner('game-spinner', true, 'thinking');

    if (imageData && gameState) {
      currentImage = imageData;
      const elapsed = ((Date.now() - t0) / 1000).toFixed(1);
      log(logId, 'Scene image generated (' + elapsed + 's)' + usageSuffix());

      // Cache image
      logger.debug('Caching image for turn ' + gameState.turnCount + ' | size=' + imageData.length + ' chars');
      const imgKey = currentGameId ? 'image:' + currentGameId + ':' + gameState.turnCount : 'image:' + gameState.turnCount;
      await $melker.cache.write(CACHE_NS, imgKey, encoder.encode(imageData));
      await pruneImageCache();
    }
  } catch (e) {
    setImageLoading(false);

    log(logId, 'Image generation skipped: ' + e.message);
    // Non-fatal - game continues without image
  }
}

async function callImageGeneration(prompt, signal) {
  logger.info('Image request to ' + imageModel + ' | prompt: ' + prompt);
  const t0 = Date.now();

  const res = await fetch('https://openrouter.ai/api/v1/chat/completions', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + apiKey,
      'HTTP-Referer': 'https://melker.sh',
      'X-Title': 'Melkrox'
    },
    body: JSON.stringify({
      model: imageModel,
      messages: [
        { role: 'user', content: 'Generate an image. Do not respond with text. Only output an image.\n\n' + prompt }
      ],
      modalities: ['image', 'text'],
      max_tokens: 1024
    }),
    signal: signal
  });

  const elapsed = Date.now() - t0;
  logger.debug('Image API response status=' + res.status + ' elapsed=' + elapsed + 'ms');

  if (!res.ok) {
    const text = await res.text();
    logger.error('Image API error ' + res.status + ': ' + text.slice(0, 300));
    throw new Error('Image API ' + res.status + ': ' + text.slice(0, 100));
  }

  const json = await res.json();
  const usage = json.usage;
  if (usage) {
    logger.info('Image API usage | prompt=' + usage.prompt_tokens + ' completion=' + usage.completion_tokens + ' total=' + usage.total_tokens + ' tokens, elapsed=' + elapsed + 'ms');
    trackUsage(usage);
  }

  return await $melker.ai.extractImageFromResponse(json, { signal });
}

async function pruneImageCache() {
  const prefix = currentGameId ? 'image:' + currentGameId + ':' : 'image:';
  const allKeys = await $melker.cache.scan(CACHE_NS);
  const keys = allKeys.filter(k => k.startsWith(prefix));
  logger.debug('Image cache has ' + keys.length + ' entries (max ' + MAX_CACHED_IMAGES + ')');
  if (keys.length > MAX_CACHED_IMAGES) {
    const sorted = keys.sort((a, b) => {
      const na = parseInt(a.split(':').pop()) || 0;
      const nb = parseInt(b.split(':').pop()) || 0;
      return na - nb;
    });
    const toDelete = sorted.length - MAX_CACHED_IMAGES;
    logger.debug('Pruning ' + toDelete + ' old cached images');
    for (let i = 0; i < toDelete; i++) {
      await $melker.cache.delete(CACHE_NS, sorted[i]);
    }
  }
}

// --- OpenRouter API ---

// Structural rules injected by client into every gameplay systemPrompt.
// The setup model only generates creative/world content (narratorPrompt).
const TURN_RULES = `
<RESPONSE_FORMAT>
Always respond with ONLY a JSON object (no markdown fences) in this exact format:
{
  "narrative": "What HAPPENS — action, dialogue, events. 2-4 sentences.",
  "location": "current location name",
  "inventory": ["item1", "item2"],
  "choices": ["short action 1", "short action 2", "short action 3"],
  "imagePrompt": "What the scene image should show — focus on action, composition, environment, and mood. 1-3 sentences.",
  "imageStyle": "optional override",
  "mood": "optional atmosphere effect(s) — string or [string, string] (max 2)",
  "stateUpdates": [{"set": "key", "value": "value"}, {"delete": "key"}]
}
Keep narratives SHORT (2-4 sentences). Focus on what happens — action, dialogue, discovery, consequences. Describe a character's appearance when they first appear, but do not repeat it in subsequent scenes. Choice labels under 6 words. Small terminal window — brevity is essential.
imagePrompt is REQUIRED — describe what the scene image should show. Lead with ACTION, COMPOSITION, and ENVIRONMENT — what's happening, where, the mood. For each character in the scene, include a brief visual tag (e.g. "copper-haired woman in a denim jacket") but do NOT dump their full appearance description. Keep it cinematic: think camera angle, framing, atmosphere. 1-3 sentences. Example: "A copper-haired woman in a denim jacket crouches behind a shipping crate on a rain-soaked dock, peering at two guards by the warehouse door. Harsh sodium lights cast long shadows across wet concrete."
imageStyle is OPTIONAL — only include if this scene's mood deviates significantly from the game's default visual style (e.g. a sudden dream sequence, a flashback, a tonal shift). Omit for normal scenes.
mood is OPTIONAL — triggers animated atmosphere effect(s) on the scene image. Use sparingly for dramatic moments. Can be a single string or an array of up to 2 effects that layer together (e.g. ["rain", "darkness"] for dark rainstorm, ["fog", "magic"] for enchanted mist). Available: "lightning" (storm bolts), "rain" (falling streaks), "bloom" (warm glow), "sunrays" (golden beams), "glitch" (digital distortion), "fog" (drifting mist), "fire" (flickering from below), "underwater" (blue-green caustics), "snow" (drifting flakes, cold tint), "darkness" (heavy vignette, low visibility), "sandstorm" (horizontal orange haze), "magic" (shimmering sparkles, color shifts), "heat" (rising shimmer distortion). Omit or null for no effect. Each turn replaces the previous.
</RESPONSE_FORMAT>

<STATE_TRACKING>
stateUpdates is REQUIRED — use it to track ALL persistent world state changes. The client stores these as key/value facts and sends them back each turn in a FACTS block. This is your long-term memory — anything not in stateUpdates will be forgotten when conversation history is pruned.
Key naming conventions:
- thread:name — story thread status (e.g. "thread:crystal mystery" = "first shard found, tension rising")
- appearance:name — character appearance (e.g. "appearance:elena" = "tall, dark-haired, wearing stolen guard uniform"). Use lowercase names matching the character's actual name — for the protagonist, use their name (e.g. "appearance:marcus"), NEVER "appearance:you". Use full merged descriptions, not deltas. Update whenever a character's looks change (outfit, disguise, transformation, injury) — always write the COMPLETE current appearance including physical identity AND current clothing.
- npc:name:key — NPC state (e.g. "npc:elena:mood" = "suspicious", "npc:bartender:location" = "left heading north")
- quest:name — quest/goal progress
- Any other freeform keys for world state (e.g. "bridge_destroyed" = "true", "time_of_day" = "night")
STRICT: Always use the colon-prefixed format above. NEVER use underscore formats like name_appearance, character:name, or other variants — the client parses these prefixes.
Always include at least one thread update. Update NPC mood/location when relevant. The more state you track, the more consistent the world becomes across turns.
</STATE_TRACKING>

<INPUT_FORMAT>
User messages arrive in this tagged format:
<STATE>
<LOCATION>current location</LOCATION>
<INVENTORY>item1, item2</INVENTORY>
<TURN>turn number</TURN>
<FACTS>
thread:crystal mystery=first shard found
appearance:elena=tall, dark-haired, wearing guard uniform
npc:bartender:mood=friendly
bridge_destroyed=true
</FACTS>
</STATE>
<ACTION>player's action text</ACTION>

Use the STATE tags to maintain consistency. The FACTS block is your long-term memory — use it to stay consistent even when old conversation history has been pruned. Update facts via stateUpdates in the response.
</INPUT_FORMAT>

<CHARACTER_CONTINUITY>
The appearance: facts in FACTS are for the imagePrompt field and for state tracking — do NOT repeat character appearance descriptions in the narrative. Describe a character's looks briefly when they FIRST appear in the story, then never again unless their appearance changes. When appearance changes, include a stateUpdate setting the appearance:name key to a COMPLETE updated description — merge the original physical identity (face, hair, build, skin) with the current change. Do NOT send only the delta.
</CHARACTER_CONTINUITY>

<PACING>
NEVER let the story stall. Every turn must CHANGE something — new information, a complication, a shift in dynamics, an NPC acting on their own agenda, a discovery, a consequence arriving. If the player repeats a similar action or lingers, the world responds: NPCs move, timers advance, opportunities close, new ones open.

Rules for keeping turns interesting:
- ADVANCE at least one thread per turn. Threads should evolve visibly — escalate tensions, reveal clues, shift alliances, create deadlines.
- NPCs are NOT props. They pursue their goals whether the player engages or not. An NPC who wanted something 3 turns ago has been ACTING on it. Show the results.
- VARY the dramatic register. Alternate between tension, discovery, dialogue, action, quiet moments, and surprises. Never repeat the same beat twice in a row.
- CHOICES must include at least one unexpected or provocative option — something the player wouldn't think to type. Mix safe, risky, and lateral options. Never offer 3 variations of "continue doing what you're doing."
- COMPLICATIONS arrive naturally every 2-3 turns: interruptions, discoveries, betrayals, environmental changes, consequences of earlier actions, NPC confrontations.
- TIME PASSES. If the player's action is minor ("look around"), advance the clock — an NPC arrives, weather shifts, a sound is heard, something changes in the environment. The world is alive.
- SCENE CHANGES are good. Move the story to new locations when it serves the narrative. Don't let 3+ turns happen in one place unless dramatic events justify it.
</PACING>`;


const SETUP_SYSTEM_PROMPT = `You are a text adventure game designer known for worlds that feel lived-in and surprising. Given the player's story prompt, generate a world configuration as JSON.

<TONE_MATCHING>
CRITICAL: Match the tone of EVERYTHING you generate to the player's prompt. A comedy prompt gets a funny, lighthearted world. A horror prompt gets a dark, tense world. A romance gets warmth and charm. A slice-of-life gets everyday stakes and gentle humor. Do NOT default to dark/gritty — read the prompt and calibrate accordingly. The tone field you generate drives everything else.
</TONE_MATCHING>

<ORIGINALITY>
Avoid genre clichés and stock characters. Build worlds that feel specific and real, not assembled from tropes:
- Characters should have contradictions — a ruthless negotiator who fosters rescue cats, a librarian who runs underground poker nights. Give them quirks, flaws, and agendas that don't align neatly with their role.
- Locations should have texture and history — not "a dark forest" but "a pine forest where someone has nailed hand-painted warnings to every third tree". Specific beats generic.
- Subvert expectations — if the genre suggests a wise mentor, make them unreliable. If it suggests a villain, give them a sympathetic reason. Avoid the obvious path.
- Names should feel grounded in the setting's culture. No "Shadowblade" or "Lord Darkmore". Real-sounding names with personality.
- Story threads should create tension through competing interests, not through obvious good-vs-evil framing. Moral ambiguity makes choices interesting.
</ORIGINALITY>

<OUTPUT_FORMAT>
Respond with ONLY a JSON object (no markdown fences) with these fields:
- title: catchy game title (short, matching the tone)
- setting: 2-3 sentence world description (matching the tone)
- tone: one-line tone descriptor
- locations: array of 5-8 starting location names
- characters: array of 3-5 NPC objects, each with: name, description (one-line role/personality), appearance (2-3 sentences describing physical appearance, clothing, distinctive features — enough detail to generate a consistent image of them), motivation (what this character wants — their personal agenda that they pursue independently of the player)
- protagonist: object with name, appearance (2-3 sentences describing the player character's physical appearance — MUST include gender, approximate age, hair color/style, skin tone, build/height, and clothing. Be specific enough to generate a consistent image every time, e.g. "A tall, lean woman in her late twenties with short copper hair and pale freckled skin, wearing a faded denim jacket over a black turtleneck.")
- threads: array of 3-5 story thread objects, each with: name (short label), description (1-2 sentences describing the driving force — could be tension, mystery, romance, humor, rivalry, friendship, ambition, or any narrative engine appropriate to the tone). NOT explicit goals — underlying narrative currents woven organically. Mix scales: one overarching thread, a few local/personal ones.
- imageStyle: one sentence describing ONLY the visual palette, lighting, and mood for scene illustrations. NO scene-specific objects, props, or details — those come from the scene text. Examples: "Warm golden palette, soft diffused lighting, cozy mood" for slice-of-life, "Deep shadows, desaturated blues, oppressive atmosphere" for horror, "Bright saturated colors, dynamic contrast, playful energy" for comedy.
- imageConstraints: TECHNICAL rendering constraints ONLY — format, medium, line weight, what to avoid. Do NOT repeat palette, lighting, or mood here (that belongs in imageStyle). If the player's prompt suggests or implies a visual medium — through explicit request, genre conventions, setting, or tone — generate constraints for that medium. Set to null only if no stylistic cues at all. Always include "Wide 3:1 format" and "NO text". Examples: null (default), "Wide 3:1 format. Photorealistic. Cinematic depth of field. NO text, NO crowds.", "Wide 3:1 format. Bold outlines, flat color fills, comic panel style. NO fine hatching, NO text.", "Wide 3:1 format. Soft watercolor edges, translucent layers. NO sharp lines, NO text."
- narratorPrompt: the creative narrator instructions for gameplay. Include the world setting, tone, NPC descriptions with motivations, and storytelling rules. The voice and language must match the tone — a comedy should encourage humor and wit, horror should encourage dread, romance should encourage chemistry. Include story threads and instruct the narrator to weave them naturally. NPCs are independent actors who pursue their agendas whether the player is present or not. Actions have consequences proportional to the tone.
</OUTPUT_FORMAT>

<LANGUAGE>
Detect the language of the player's prompt. ALL content (title, setting, narrative, locations, characters, choices, threads, narratorPrompt) MUST be in that same language. If the prompt is in Swedish, everything must be in Swedish. If in English, everything in English.
</LANGUAGE>`;

async function callOpenRouter(systemPrompt, messages, useModel) {
  const m = useModel || model;
  const msgCount = messages.length;
  const sysLen = systemPrompt.length;
  const totalChars = messages.reduce((sum, m) => sum + m.content.length, sysLen);
  logger.info('API request to ' + m + ' | messages=' + msgCount + ' systemPrompt=' + sysLen + ' chars, totalInput=' + totalChars + ' chars');
  logger.info('System prompt: ' + systemPrompt);
  for (const msg of messages) {
    logger.info('[' + msg.role + '] ' + msg.content);
  }

  const body = {
    model: m,
    messages: [
      { role: 'system', content: systemPrompt },
      ...messages
    ],
    temperature: 0.8,
    max_tokens: 2048
  };

  const bodyJson = JSON.stringify(body);
  logger.debug('POST openrouter.ai/api/v1/chat/completions | bodySize=' + bodyJson.length + ' bytes');
  const t0 = Date.now();

  const res = await fetch('https://openrouter.ai/api/v1/chat/completions', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + apiKey,
      'HTTP-Referer': 'https://melker.sh',
      'X-Title': 'Melkrox'
    },
    body: bodyJson
  });

  const elapsed = Date.now() - t0;
  logger.debug('API response status=' + res.status + ' elapsed=' + elapsed + 'ms');

  if (!res.ok) {
    const text = await res.text();
    logger.error('API error ' + res.status + ': ' + text.slice(0, 300));
    throw new Error('API error ' + res.status + ': ' + text.slice(0, 200));
  }

  const json = await res.json();
  const content = json.choices?.[0]?.message?.content;
  const usage = json.usage;
  if (usage) {
    logger.info('API usage | prompt=' + usage.prompt_tokens + ' completion=' + usage.completion_tokens + ' total=' + usage.total_tokens + ' tokens, elapsed=' + elapsed + 'ms');
    trackUsage(usage);
  }
  if (!content) {
    logger.error('Empty API response | raw=' + JSON.stringify(json).slice(0, 300));
    throw new Error('Empty API response');
  }
  logger.debug('API response content length=' + content.length + ' chars');
  return content;
}

async function callOpenRouterStreaming(systemPrompt, messages) {
  logger.info('Streaming request to ' + model + ' | messages=' + messages.length);
  logger.info('System prompt: ' + systemPrompt);
  const lastMsg = messages[messages.length - 1];
  if (lastMsg) logger.info('Latest [' + lastMsg.role + '] ' + lastMsg.content);

  const body = {
    model: model,
    stream: true,
    messages: [
      { role: 'system', content: systemPrompt },
      ...messages
    ],
    temperature: 0.8,
    max_tokens: 2048
  };

  const res = await fetch('https://openrouter.ai/api/v1/chat/completions', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + apiKey,
      'HTTP-Referer': 'https://melker.sh',
      'X-Title': 'Melkrox'
    },
    body: JSON.stringify(body)
  });

  if (!res.ok) {
    const errText = await res.text();
    logger.error('Streaming error ' + res.status + ': ' + errText.slice(0, 300));
    throw new Error('API error ' + res.status + ': ' + errText.slice(0, 200));
  }

  const narrativeEl = $melker.getElementById('narrative');
  const stream = $melker.ai.createStreamingExtractor(res.body, {
    onField: {
      narrative: (partial) => {
        narrativeEl.props.text = partial;
        $melker.render();
      },
    },
    onUsage: trackUsage,
  });

  return await stream.result;
}

async function callOpenRouterStreamingWithModel(systemPrompt, messages, useModel, onChunk) {
  const m = useModel || model;
  logger.info('Streaming request to ' + m + ' | messages=' + messages.length);

  const body = {
    model: m,
    stream: true,
    messages: [
      { role: 'system', content: systemPrompt },
      ...messages
    ],
    temperature: 0.8,
    max_tokens: 4096
  };

  const res = await fetch('https://openrouter.ai/api/v1/chat/completions', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + apiKey,
      'HTTP-Referer': 'https://melker.sh',
      'X-Title': 'Melkrox'
    },
    body: JSON.stringify(body)
  });

  if (!res.ok) {
    const errText = await res.text();
    throw new Error('API error ' + res.status + ': ' + errText.slice(0, 200));
  }

  const stream = $melker.ai.createStreamingExtractor(res.body, {
    onContent: onChunk || undefined,
    onUsage: trackUsage,
  });

  return await stream.result;
}

// --- Helpers ---


function parseJSON(text) {
  try {
    let cleaned = text.trim();
    if (cleaned.startsWith('```')) {
      cleaned = cleaned.replace(/^```\w*\n?/, '').replace(/\n?```$/, '');
    }
    return JSON.parse(cleaned);
  } catch (_) {
    // Fallback: extract fields from partial/broken JSON
    return extractPartialJSON(text);
  }
}

function extractPartialJSON(text) {
  // Try to extract structured fields even from truncated JSON
  const narrative = extractJsonString(text, 'narrative');
  if (!narrative) return null;

  const result = { narrative: narrative };
  const location = extractJsonString(text, 'location');
  if (location) result.location = location;

  // Extract inventory array
  const invMatch = text.match(/"inventory"\s*:\s*\[([^\]]*)/);
  if (invMatch) {
    const items = [];
    const re = /"([^"]+)"/g;
    let m;
    while ((m = re.exec(invMatch[1])) !== null) items.push(m[1]);
    if (items.length > 0) result.inventory = items;
  }

  // Extract choices array
  const choicesMatch = text.match(/"choices"\s*:\s*\[([^\]]*)/);
  if (choicesMatch) {
    const items = [];
    const re = /"([^"]+)"/g;
    let m;
    while ((m = re.exec(choicesMatch[1])) !== null) items.push(m[1]);
    if (items.length > 0) result.choices = items;
  }

  logger.debug('Extracted partial JSON | narrative=' + narrative.length + ' chars, location=' + (location || 'none'));
  return result;
}

function extractJsonString(text, key) {
  const marker = '"' + key + '"';
  const idx = text.indexOf(marker);
  if (idx === -1) return null;
  const afterKey = text.indexOf(':', idx + marker.length);
  if (afterKey === -1) return null;
  const valStart = text.indexOf('"', afterKey + 1);
  if (valStart === -1) return null;
  // Find unescaped closing quote
  let end = -1;
  for (let i = valStart + 1; i < text.length; i++) {
    if (text[i] === '\\') { i++; continue; }
    if (text[i] === '"') { end = i; break; }
  }
  if (end === -1) return null;  // Wait for closing quote
  const raw = text.slice(valStart + 1, end);
  return raw.replace(/\\n/g, '\n').replace(/\\t/g, '\t').replace(/\\"/g, '"').replace(/\\\\/g, '\\');
}

async function saveState() {
  if (!gameState || !currentGameId) return;
  const data = JSON.stringify(gameState);
  logger.debug('Saving state | game=' + currentGameId + ' turn=' + gameState.turnCount + ' history=' + gameState.history.length + ' messages, size=' + data.length + ' chars');
  await $melker.cache.write(CACHE_NS, 'game:' + currentGameId, encoder.encode(data));

  // Update index entry
  const entry = gamesIndex.find(g => g.id === currentGameId);
  if (entry) {
    entry.title = gameState.worldConfig?.title || entry.title;
    entry.turnCount = gameState.turnCount;
    entry.location = gameState.location;
    entry.lastPlayed = new Date().toISOString();
  }
  await saveGamesIndex();
}

function showError(id, msg) {
  const el = $melker.getElementById(id);
  el.props.text = msg;
  el.props.style = { ...el.props.style, display: 'flex' };
}

function setSpinner(id, on, verbs) {
  const spinner = $melker.getElementById(id);
  spinner.props.spinning = on;
  if (verbs) spinner.props.verbs = verbs;
  spinner.props.style = { ...spinner.props.style, visibility: on ? 'visible' : 'hidden' };
  // Don't tie loading shader to spinner — loading shader is managed explicitly
  // at turn start and image completion to avoid flicker
}



function focusInput() {
  setTimeout(() => {
    $melker.engine.focusElement('cmd-input');
  }, 50);
}

function showScreen(id) {
  for (const s of ['loading-screen', 'select-screen', 'setup-container', 'game-screen']) {
    const el = $melker.getElementById(s);
    el.props.style = { ...el.props.style, display: s === id ? 'flex' : 'none' };
  }
  // Stop all spinners to prevent hidden animations
  for (const spinnerId of ['loading-spinner', 'setup-spinner', 'game-spinner']) {
    $melker.getElementById(spinnerId).stop();
  }
  setImageLoading(false);
  // Clear scene image to prevent old image flicker on next game screen show
  if (id !== 'game-screen') {
    $melker.getElementById('scene-image').setSrc(PLACEHOLDER_IMG);
  }
}

function showGameScreen() { showScreen('game-screen'); }
function showSetupScreen() { showScreen('setup-container'); }
function showSelectScreen() {
  renderGamesList();
  showScreen('select-screen');
}

function renderScene() {
  if (!gameState) return;

  const title = gameState.worldConfig?.title || 'MELKROX';
  $melker.getElementById('title-bar').props.text =
    'MELKROX - ' + title + '    Turn: ' + gameState.turnCount;

  // Scene image — always visible
  const imgEl = $melker.getElementById('scene-image');
  if (currentImage) {
    imgEl.setSrc(currentImage);
    // Clear loading shader only when a new image has arrived (not the stale old one)
    if (shaderPipeline[2] && currentImage !== lastRenderedImage) {
      setImageLoading(false);
    }
    lastRenderedImage = currentImage;
  } else if (!shaderPipeline[2]) {
    // No image yet — load placeholder and show loading shader
    imgEl.setSrc(PLACEHOLDER_IMG);
    setImageLoading(true);
    lastRenderedImage = null;
  }

  $melker.getElementById('narrative').props.text = gameState.currentScene || '*Waiting...*';

  const inv = gameState.inventory.length > 0 ? gameState.inventory.join(', ') : 'empty';
  $melker.getElementById('status-bar').props.text =
    'Location: ' + gameState.location + '    Inventory: ' + inv;

  const choicesBar = $melker.getElementById('choices-bar');
  choicesBar.children = [];
  if (gameState.choices && gameState.choices.length > 0) {
    for (const rawChoice of gameState.choices) {
      const choice = typeof rawChoice === 'string' ? rawChoice : (rawChoice.label || rawChoice.text || String(rawChoice));
      const btn = $melker.createElement('button', {
        label: choice,
        variant: 'plain',
        class: 'choice-btn',
        onClick: () => {
          $melker.getElementById('cmd-input').props.value = choice;
          $app.handleInput();
        }
      });
      choicesBar.children.push(btn);
    }
  }
}

// --- AI Assistant Tools ---

$melker.registerAITool({
  name: 'get_game_context',
  description: 'Get current game state including world, location, inventory, characters, story threads, and available commands',
  parameters: {},
  handler: () => {
    if (!gameState) return { status: 'no_game', message: 'No game is currently active' };
    const wc = gameState.worldConfig || {};
    return {
      title: wc.title,
      setting: wc.setting,
      tone: wc.tone,
      location: gameState.location,
      inventory: gameState.inventory,
      turn: gameState.turnCount,
      scene: gameState.currentScene,
      choices: gameState.choices,
      facts: gameState.facts || {},
      characters: (wc.characters || []).map(c => ({ name: c.name, description: c.description })),
      protagonist: wc.protagonist ? { name: wc.protagonist.name } : null,
      threads: wc.threads,
      commands: '/new, /games, /undo, /redo, /state, /story, /image, /reimage [style], /images, /gfx [mode], /dither [bits], /history, /help',
    };
  }
});

$melker.registerAITool({
  name: 'play_action',
  description: 'Send a game action or command as if the player typed it. Use for gameplay actions like "look around", "pick up key", or commands like "/undo", "/reimage"',
  parameters: {
    action: { type: 'string', required: true, description: 'The action text or command to send' }
  },
  handler: (args) => {
    if (!args.action) return { success: false, message: 'No action provided' };
    const input = $melker.getElementById('cmd-input');
    input.props.value = args.action;
    $app.handleInput();
    return { success: true, message: 'Action sent: ' + args.action };
  }
});

// --- Init on mount ---

$melker.engine.onMount(async () => {
  const logId = 'loading-log';

  apiKey = $melker.config.getString('openrouter.key', '');
  model = $melker.config.getString('openrouter.model', 'anthropic/claude-haiku-4-5');
  setupModel = 'anthropic/claude-sonnet-4';
  imageModel = $melker.config.getString('openrouter.imageModel', 'openai/gpt-image-1');
  visionModel = $melker.config.getString('openrouter.visionModel', 'google/gemini-2.5-flash');
  skipImages = $melker.config.getString('openrouter.skipImages', 'false') === 'true';

  log(logId, 'Setup model: ' + setupModel + ' | Turn model: ' + model + (skipImages ? ' | Images: SKIPPED' : ''));
  log(logId, 'Image model: ' + imageModel + ' | Vision: ' + visionModel);

  if (!apiKey) {
    $melker.toast.show('No API key found. Set OPENROUTER_API_KEY', { type: 'error' });
    showSetupScreen();
    showError('setup-error', 'Set OPENROUTER_API_KEY environment variable to play.');
    $melker.render();
    return;
  }

  log(logId, 'API key configured');

  // Check for --new flag
  const args = (typeof argv !== 'undefined' && Array.isArray(argv)) ? argv : [];
  const forceNew = args.includes('new');
  const forceGames = args.includes('games');

  log(logId, 'Loading saved games...');

  await loadGamesIndex();

  if (forceGames && gamesIndex.length > 0) {
    log(logId, 'Showing saved games (--games)');
    showSelectScreen();
    $melker.render();
    return;
  }

  if (forceNew || gamesIndex.length === 0) {
    log(logId, forceNew ? 'Starting new game (--new)' : 'No saved games found');
    newGame();
    $melker.render();
    return;
  }

  // Auto-resume most recently played game
  const sorted = [...gamesIndex].sort((a, b) => (b.lastPlayed || '').localeCompare(a.lastPlayed || ''));
  const lastGame = sorted[0];
  log(logId, 'Resuming "' + lastGame.title + '"...');
  await loadGame(lastGame.id);
  if (gameState) {
    log(logId, 'Turn: ' + gameState.turnCount + ', Location: ' + gameState.location);
    showGameScreen();
    renderScene();
    focusInput();
    $melker.render();
    return;
  }

  log(logId, gamesIndex.length + ' saved games found');
  showSelectScreen();
  $melker.render();
});

</script>
</melker>
